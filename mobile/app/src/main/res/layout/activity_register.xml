<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        tools:context=".RegisterActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/include_brand_header" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_account"
                        android:textAppearance="@style/RentEase.FormTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/register_subtitle"
                        android:textAppearance="@style/RentEase.FormSubtitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:hint="@string/first_name"
                            style="@style/Widget.RentEase.TextInputLayout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/firstname_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:autofillHints="givenName"
                                android:inputType="textPersonName"
                                android:textColor="@color/rentease_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/last_name"
                            style="@style/Widget.RentEase.TextInputLayout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/lastname_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:autofillHints="familyName"
                                android:inputType="textPersonName"
                                android:textColor="@color/rentease_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/email"
                        style="@style/Widget.RentEase.TextInputLayout">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/email_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="emailAddress"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/rentease_text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/i_am_a"
                        android:textColor="@color/rentease_text_primary"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/role_toggle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:checkedButton="@+id/btn_role_renter"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_role_renter"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/role_renter"
                            app:strokeColor="@color/box_stroke_rentease" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_role_owner"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/role_owner"
                            app:strokeColor="@color/box_stroke_rentease" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/password"
                        app:endIconMode="password_toggle"
                        style="@style/Widget.RentEase.TextInputLayout">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/password_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="newPassword"
                            android:inputType="textPassword"
                            android:textColor="@color/rentease_text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/confirm_password"
                        app:endIconMode="password_toggle"
                        style="@style/Widget.RentEase.TextInputLayout">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/confirm_password_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="@color/rentease_text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/error_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_error_soft"
                        android:padding="10dp"
                        android:textColor="@color/rentease_accent_plum"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Error"
                        tools:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register"
                        style="@style/Widget.RentEase.Button.SignIn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/sign_up" />

                    <ProgressBar
                        android:id="@+id/progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:indeterminateTint="@color/rentease_primary"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/link_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:padding="8dp"
                        android:text="@string/have_account_sign_in"
                        android:textAppearance="@style/Widget.RentEase.Link" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
