<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.RentEase.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/box_stroke_rentease</item>
        <item name="hintTextColor">@color/rentease_text_secondary</item>
        <item name="android:textColorHint">@color/rentease_text_secondary</item>
    </style>

    <style name="RentEase.FormTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/rentease_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="RentEase.FormSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/rentease_text_secondary</item>
    </style>

    <style name="RentEase.BrandName" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="RentEase.BrandTagline" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/rentease_tagline</item>
        <item name="lineHeight">18sp</item>
    </style>

    <style name="RentEase.FeatureLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/rentease_tagline</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.RentEase.Button.SignIn" parent="Widget.Material3.Button.UnelevatedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/bg_btn_signin</item>
        <item name="android:elevation">2dp</item>
    </style>

    <style name="Widget.RentEase.Link" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/rentease_link</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
